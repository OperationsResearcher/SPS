# --- FLASK KONFIGURASYONU ---
# Uygulamanın giriş dosyası (Sizde app.py mi run.py mi? Genelde run.py ise burayı değiştirin)
FLASK_APP=app.py
FLASK_ENV=development
# Bu anahtarı üretim ortamında mutlaka değiştirin!
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# --- VERITABANI (PostgreSQL zorunlu) ---
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://kullanici:sifre@localhost:5432/kokpitim
# Test: TEST_DATABASE_URI=sqlite:///:memory:

# --- REDIS (üretimde önerilir: rate limit + cache) ---
REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# --- GOOGLE GEMINI API (AI Coach) ---
GEMINI_API_KEY=your-gemini-api-key-here
# Opsiyonel: Model adi (ornek: gemini-2.0-flash, gemini-2.5-flash, gemini-pro). Bos birakilirsa sirayla denenir.
# GEMINI_MODEL=gemini-2.0-flash

# --- OTURUM VE GUVENLIK ---
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=3600
CSRF_ENABLED=True
WTF_CSRF_ENABLED=True

# --- DOSYA YUKLEME ---
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=static/uploads

# --- LOGLAMA VE DIGERLERI ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
RATELIMIT_ENABLED=True
# Yerel geliştirmede memory:// yeterli; üretimde REDIS_URL kullanın
RATELIMIT_STORAGE_URL=memory://

# --- EMAIL (Opsiyonel) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password