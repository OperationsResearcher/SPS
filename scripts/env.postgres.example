# VM: /home/kokpitim.com/public_html/.env.postgres olarak kopyalayin (git'e eklemeyin).
# Asil .env ile birlestirilir: docker run --env-file .env --env-file .env.postgres
#
# Ornek (sifreyi ve hostu kendi kurulumunuza gore degistirin):
# VM Docker: PostgreSQL ana makinede — asagidaki host cogu kurulumda calisir:
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://kokpitim_user:SIFRE@host.docker.internal:5432/kokpitim_db
#
# vm_safe_deploy.sh: --add-host=host.docker.internal:host-gateway kullanilir.

SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://KULLANICI:SIFRE@host.docker.internal:5432/kokpitim_db
