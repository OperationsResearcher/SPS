# =============================================================================
# KOKPITIM — PRODUCTION .env ŞABLONU
# =============================================================================
# Bu dosyayı .env.production olarak kopyalayıp DEĞERLERİ DEĞİŞTİRİN.
# .env.production dosyası VERSIYON KONTROLE GİRMEMELI (.gitignore'da olmalı).
# =============================================================================

# Ortam
FLASK_ENV=production
DEBUG=False

# --- KRİTİK GÜVENLİK ANAHTARLARI ---
# Her tenant deployment'ı için BENZERSİZ değerler.
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_32_BAYTLIK_HEX_GIRIN_DEV_KEY_KULLANMAYIN

# --- VERİTABANI ---
# Production: postgresql+psycopg2://user:GUCLU_SIFRE@host:5432/dbname
# Kullanıcı için en az 16 karakter random şifre kullan
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://kokpitim_prod:DEGISTIRILECEK_PROD_SIFRESI@localhost:5432/kokpitim_prod

# --- CACHE ve RATE LIMIT (Redis önerilir) ---
CACHE_TYPE=RedisCache
CACHE_REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# --- COOKIE / SESSION ---
SESSION_COOKIE_SAMESITE=Strict
PREFERRED_URL_SCHEME=https

# --- E-POSTA ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=noreply@kurum.com
MAIL_PASSWORD=DEGISTIRILECEK
MAIL_SENDER=noreply@kurum.com
MAIL_SENDER_NAME=Kokpitim

# --- HGS BYPASS (PROD'da KESİNLİKLE False) ---
HGS_BYPASS_ENABLED=False

# --- LEGACY FEATURE FLAGS ---
LEGACY_PROCESS_BP_ENABLED=False
LEGACY_DASHBOARD_BP_ENABLED=False
LEGACY_SUNSET_ENABLED=True

# --- DIGEST EMAIL SCHEDULER ---
DIGEST_SCHEDULER_ENABLED=True

# --- SSO (opsiyonel) ---
GOOGLE_OAUTH_ENABLED=False
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SSO_AUTO_PROVISION=False
SSO_DEFAULT_TENANT_ID=1

# --- SENTRY (opsiyonel, prod monitoring) ---
SENTRY_DSN=

# --- BASE URL (mail link'leri için) ---
BASE_URL=https://kokpitim.kurum.com

# --- VERSION (cache busting) ---
VERSION=1.0.7
