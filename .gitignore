# ============================================================
# Kokpitim — .gitignore
# ============================================================

# ------------------------------------------------------------
# ORTAM DEĞİŞKENLERİ — KESİNLİKLE COMMIT ETME
# ------------------------------------------------------------
.env
.env.*
.env.local
.env.production

# ------------------------------------------------------------
# VERİTABANI
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
instance/

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# VIRTUAL ENVIRONMENT
# ------------------------------------------------------------
venv/
.venv/
env/
.env/

# ------------------------------------------------------------
# FLASK / UYGULAMA
# ------------------------------------------------------------
*.log
flask_session/
.webassets-cache

# ------------------------------------------------------------
# PROJE ÖZEL
# ------------------------------------------------------------
SPS_DATA/
instance/
eski_proje/

# ------------------------------------------------------------
# IDE & EDITOR
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# KİRO — Steering dosyaları GitHub'a gider, cache gitmez
# ------------------------------------------------------------
.kiro/cache/
.kiro/tmp/
# NOT: .kiro/steering/ klasörü AÇIK — GitHub'a gider

# ------------------------------------------------------------
# İŞLETİM SİSTEMİ
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# GOOGLE DRIVE SYNC
# ------------------------------------------------------------
.tmp.driveupload
.tmp.driveupload*
*.gdoc
*.gsheet

# ------------------------------------------------------------
# TEST & COVERAGE
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ------------------------------------------------------------
# NODE (varsa)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
