msgstr "AI Sector Assessment — report card."

#: ⁨system_cards.description (DB)⁩
msgid "WT — Geri Çekilmeci (Zayıf×Tehdit) strateji kombinasyonu kartı."
msgstr "WT — Defensive Retreat (Weakness × Threat) strategy combination card."

#: ⁨system_cards.description (DB)⁩
msgid ""
"Aktif replan tetikleyici sayısını ve son 7 günde ateşlenen tetikleyici "
